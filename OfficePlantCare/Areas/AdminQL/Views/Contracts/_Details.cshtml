@model OfficePlantCare.Models.Contract

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Contract</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ContractCode)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ContractCode)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DurationUnit)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DurationUnit)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Duration)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Duration)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.TotalAmount)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TotalAmount)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.StartDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.StartDate)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.EndDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.EndDate)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.PaymentStatus)
        </dt>
        <dd class="col-sm-10">
                @if (Model.PaymentStatus == "Đã thanh toán")
                {
                <span class="badge badge-success px-3 py-2">Đã thanh toán</span>
                }
                else if (Model.PaymentStatus == "Thanh toán 1 phần")
                {
                <span class="badge badge-info px-3 py-2">Thanh toán 1 phần</span>
                }
                else if (Model.PaymentStatus == "Chưa thanh toán")
                {
                <span class="badge badge-warning px-3 py-2">Chưa thanh toán</span>
                }
                else if (Model.PaymentStatus == "Hoàn tiền")
                {
                <span class="badge badge-danger px-3 py-2">Hoàn tiền</span>
                }
                else
                {
                <span class="badge badge-secondary px-3 py-2">Chưa xác định</span>
                }
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class="col-sm-10">
            @if (Model.Status == "Đang hiệu lực")
            {
                <span class="badge badge-success px-3 py-2">Đang hiệu lực</span>
            }
            else if (Model.Status == "Hết hiệu lực")
            {
                <span class="badge badge-secondary px-3 py-2">Hết hiệu lực</span>
            }
            else if (Model.Status == "Chờ xử lý")
            {
                <span class="badge badge-warning px-3 py-2">Chờ xử lý</span>
            }
            else
            {
                <span class="badge badge-danger px-3 py-2">Hủy</span>
            }
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Customer)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Customer.CustomerName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.PaymentMethod)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.PaymentMethod.MethodName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Price)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Price.PriceId)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Service)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Service.ServiceName)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.ContractId">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
