@model OfficePlantCare.Models.News

@{
    ViewData["Title"] = "Chi tiết tin tức";
}

<link rel="stylesheet" href="~/assets/css/index.css" />

<!-- [ Main Content ] start -->
<div class="pcoded-main-container">
    <div class="pcoded-content">
        <!-- Page Header -->
        <div class="page-header card shadow-sm border-0">
            <div class="page-block">
                <div class="row align-items-center">
                    <div class="col-md-12">
                        <div class="page-header-title d-flex justify-content-between align-items-center py-3 ml-3">
                            <h5 class="m-0 text-success font-weight-bold">QUẢN LÝ TIN TỨC</h5>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb mb-0 bg-transparent">
                                    <li class="breadcrumb-item"><a asp-area="AdminQL" asp-controller="News" asp-action="Index"><i class="fas fa-home"></i></a></li>
                                    <li class="breadcrumb-item active" aria-current="page">CHI TIẾT TIN TỨC</li>
                                </ol>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="row">
            <div class="col-sm-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white px-4 py-3 border-bottom">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="text-success font-weight-bold mb-0">CHI TIẾT TIN TỨC</h5>
                            <div class="d-flex align-items-center gap-3">
                                @* <a class="btn btn-success rounded-pill px-4" asp-action="Edit" asp-route-id="@Model?.NewsId">
                                <i class="fas fa-edit"></i> Sửa
                                </a> *@
                                <a class="btn btn-secondary rounded-pill px-4" asp-action="Index">
                                    <i class="fas fa-arrow-left"></i> Quay lại
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="card-body p-4">
                        <div class="row">
                            <!-- Hình ảnh tin tức -->
                            @if (!string.IsNullOrEmpty(Model.Image))
                            {
                                <div class="col-md-4 mb-3">
                                    <div class="card h-100">
                                        <img src="@Model.Image" class="card-img-top img-fluid" alt="Hình ảnh tin tức" style="object-fit: cover; height: 250px; border-radius: 10px;">
                                        <div class="card-body text-center">
                                            <p class="text-muted">Hình ảnh minh họa</p>
                                        </div>
                                    </div>
                                </div>
                            }
                            <div class="@(string.IsNullOrEmpty(Model.Image) ? "col-12" : "col-md-8")">
                                <dl class="row">
                                    <dt class="col-sm-4 text-muted font-weight-bold">Tiêu đề:</dt>
                                    <dd class="col-sm-8">
                                        <span class="badge bg-primary text-white px-3 py-2">@Model.Title</span>
                                    </dd>

                                    <dt class="col-sm-4 text-muted font-weight-bold">Mô tả:</dt>
                                    <dd class="col-sm-8">
                                        <p class="text-break">@Model.Description</p>
                                    </dd>

                                    <dt class="col-sm-4 text-muted font-weight-bold">Ngày tạo:</dt>
                                    <dd class="col-sm-8">
                                        <span class="badge bg-info text-white px-3 py-2">@Model.CreatedDate?.ToString("dd/MM/yyyy HH:mm")</span>
                                    </dd>

                                    <dt class="col-sm-4 text-muted font-weight-bold">Ngày cập nhật:</dt>
                                    <dd class="col-sm-8">
                                        <span class="badge bg-secondary text-white px-3 py-2">@(Model.UpdatedDate?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa cập nhật")</span>
                                    </dd>

                                    <dt class="col-sm-4 text-muted font-weight-bold">Trạng thái:</dt>
                                    <dd class="col-sm-8">
                                        @if (Model.Status == "Hiển thị")
                                        {
                                            <span class="badge badge-success px-3 py-2">Hiển thị</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-warning px-3 py-2">Ẩn</span>
                                        }
                                    </dd>

                                    <dt class="col-sm-4 text-muted font-weight-bold">Nội dung:</dt>
                                    <dd class="col-sm-8">
                                        <div class="card p-3 bg-light" style="min-height: 150px; overflow-y: auto;">
                                            @Html.Raw(Model.Content)
                                        </div>
                                    </dd>
                                </dl>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- [ Main Content ] end -->
<style>
    .card {
        transition: all 0.3s ease;
    }

        .card:hover {
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
            transform: translateY(-5px);
        }

    .card-img-top {
        transition: transform 0.3s ease;
    }

        .card-img-top:hover {
            transform: scale(1.05);
        }

    .card .bg-light {
        border: 1px solid #dee2e6;
        border-radius: 5px;
    }
</style>
