@model OfficePlantCare.Models.Staff
<dl class="row">
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.StaffName)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.StaffName)
    </dd>
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.Position)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Position)
    </dd>
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.Phone)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Phone)
    </dd>
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.Email)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Email)
    </dd>
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.Avatar)
    </dt>
    <dd class="col-sm-10">
        <img src="@Url.Content(Model.Avatar)" alt="Avatar" class="img-fluid rounded" style="max-width: 80px;" />
    </dd>
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.BirthDate)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.BirthDate)
    </dd>
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.HireDate)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.HireDate)
    </dd>
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.Salary)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Salary)
    </dd>
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.Status)
    </dt>
    <dd class="col-sm-10">
        @if (Model?.Status != null)
        {
            if (Model.Status.ToString() == "Đang làm")
            {
                <span class="text-success fw-bold">Đang làm</span> <!-- Màu xanh -->
            }
            else if (Model.Status.ToString() == "Bị sa thải")
            {
                <span class="text-warning fw-bold">Bị sa thải</span> <!-- Màu vàng -->
            }
            else
            {
                <span class="text-danger fw-bold">Nghỉ việc</span> <!-- Màu đỏ -->
            }
        }
        else
        {
            <span class="text-secondary fw-bold">Không xác định</span> <!-- Màu xám nếu giá trị null -->
        }
    </dd>
    </dd>
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.Role)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Role.RoleName)
    </dd>
</dl>

<button type="button" class="btn btn-primary" onclick="loadModal('@Url.Action("Edit", "Staffs", new { id = Model?.StaffId })')">
    Chỉnh sửa
</button>
<button type="button" class="btn btn-secondary" data-dismiss="modal">Đóng</button>
