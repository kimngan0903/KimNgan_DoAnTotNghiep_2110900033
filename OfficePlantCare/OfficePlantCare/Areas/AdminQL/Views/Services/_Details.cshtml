@model OfficePlantCare.Models.Service

<dl class="row">
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ServiceName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ServiceName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.CreatedDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.CreatedDate)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.UpdatedDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.UpdatedDate)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class="col-sm-10">
            @if (Model?.Status != null && Model.Status.ToString() == "Đang hoạt động")
            {
                <span class="text-success fw-bold">Đang hoạt động</span>
            }
            else
            {
                <span class="text-danger fw-bold">Tạm dừng</span>
            }
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Image)
        </dt>
        <dd class="col-sm-10">
            <img src="@Url.Content(Model.Image)" alt="Avatar" class="img-fluid rounded" style="max-width: 80px;" />
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.CategoryService)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.CategoryService.CategoryServiceName)
        </dd>
    </dl>
</dl>
<button type="button" class="btn btn-primary" onclick="loadModal('@Url.Action("Edit", "Services", new { id = Model?.ServiceId })')">
    Chỉnh sửa
</button>
<button type="button" class="btn btn-secondary" data-dismiss="modal">Đóng</button>
