@model OfficePlantCare.Models.Contract

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="ContractId" />
    <div class="form-group">
        <label asp-for="CustomerId" class="control-label"></label>
        <select asp-for="CustomerId" class="form-control" asp-items="ViewBag.CustomerId"></select>
        <span asp-validation-for="CustomerId" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="ServiceId" class="control-label"></label>
        <select asp-for="ServiceId" class="form-control" asp-items="ViewBag.ServiceId"></select>
        <span asp-validation-for="ServiceId" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="FixedPrice" class="control-label"></label>
        <input asp-for="FixedPrice" class="form-control" />
        <span asp-validation-for="FixedPrice" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="DurationUnit" class="control-label"></label>
        <input asp-for="DurationUnit" class="form-control" />
        <span asp-validation-for="DurationUnit" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Duration" class="control-label"></label>
        <input asp-for="Duration" class="form-control" />
        <span asp-validation-for="Duration" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="StartDate" class="control-label"></label>
        <input asp-for="StartDate" class="form-control" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="PaymentMethodId" class="control-label"></label>
        <select asp-for="PaymentMethodId" class="form-control" asp-items="ViewBag.PaymentMethodId"></select>
        <span asp-validation-for="PaymentMethodId" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="PaidAmount" class="control-label"></label>
        <input asp-for="PaidAmount" class="form-control" />
        <span asp-validation-for="PaidAmount" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="RemainingAmount" class="control-label"></label>
        <input asp-for="RemainingAmount" class="form-control" />
        <span asp-validation-for="RemainingAmount" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Status" class="control-label"></label>
        <select asp-for="Status" class="form-control">
            <option value="Đang hiệu lực">Đang hiệu lực</option>
            <option value="Đã hết hạn">Đã hết hạn</option>
            <option value="Đã hủy">Đã hủy</option>
        </select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="CreatedAt" class="control-label"></label>
        <input asp-for="CreatedAt" class="form-control" />
        <span asp-validation-for="CreatedAt" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="UpdatedAt" class="control-label"></label>
        <input asp-for="UpdatedAt" class="form-control" />
        <span asp-validation-for="UpdatedAt" class="text-danger"></span>
    </div>
 
    <button type="submit" class="btn btn-primary">Lưu</button>

</form>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
</div>
