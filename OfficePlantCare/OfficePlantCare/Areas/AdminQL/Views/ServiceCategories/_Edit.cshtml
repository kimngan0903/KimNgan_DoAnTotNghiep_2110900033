@model OfficePlantCare.Models.ServiceCategory

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="CategoryServiceId" />
    <div class="form-group">
        <label asp-for="CategoryServiceName"></label>
        <input asp-for="CategoryServiceName" class="form-control" />
        <span asp-validation-for="CategoryServiceName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Description" class="control-label"></label>
        <input asp-for="Description" class="form-control" />
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Lưu</button>
</form>
<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
</div>