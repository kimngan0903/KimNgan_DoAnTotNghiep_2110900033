@model IEnumerable<PlantCare.Models.ServiceCategory>

@{
    ViewData["Title"] = "Danh sách danh mục dịch vụ";
    Layout = "~/Areas/AdminQL/Views/Shared/Admin.cshtml";
}
<div class="pcoded-main-container">
    <div class="pcoded-content">
        <div class="page-header">
            <div class="page-block">
                <div class="row align-items-center">
                    <div class="col-md-12">
                        <div class="page-header-title">
                            <h5 class="m-b-10">Quản lý danh mục dịch vụ</h5>
                        </div>
                        <ul class="breadcrumb">
                            <li class="breadcrumb-item"><a asp-area="AdminQL" asp-controller="Home" asp-action="Index"><i class="feather icon-home"></i></a></li>
                            <li class="breadcrumb-item"><a href="#!">Danh sách danh mục dịch vụ</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-12">
                <div class="card">
                    <div class="card-header">
                        <h5>Danh sách danh mục dịch vụ</h5>
                        <div class="card-header-right">
                            <a class="btn btn-primary" asp-action="Create">Thêm mới</a>
                        </div>
                    </div>
                    <div class="card-body">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>@Html.DisplayNameFor(model => model.CategoryServiceName)</th>
                                    <th>Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@Html.DisplayFor(modelItem => item.CategoryServiceName)</td>
                                        <td>
                                            <button class="btn btn-primary btn-sm" onclick="loadModal('@Url.Action("Edit", "ServiceCategories", new { id = item.CategoryServiceId })')">Sửa</button>
                                            <button class="btn btn-info btn-sm" onclick="loadModal('@Url.Action("Details", "ServiceCategories", new { id = item.CategoryServiceId })')">Chi tiết</button>
                                            <button class="btn btn-danger btn-sm" onclick="loadModal('@Url.Action("Delete", "ServiceCategories", new { id = item.CategoryServiceId })')">Xóa</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Modal -->
<div class="modal fade" id="modal-container" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Thông tin</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body" id="modal-content">
                <!-- Nội dung sẽ được tải bằng AJAX -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function loadModal(url) {
            $.get(url, function (data) {
                $("#modal-content").html(data);
                $("#modal-container").modal("show");
            });
        }
    </script>
}



